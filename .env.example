# ── Stylo Bench — Environment Variables ─────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# Site
SITE_NAME=your-site.example.com

# Database (MariaDB)
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=your_db_name
DB_PASSWORD=your_db_password
DB_ROOT_PASSWORD=your_mariadb_root_password

# Redis
REDIS_CACHE_URL=redis://redis:6379/0
REDIS_QUEUE_URL=redis://redis:6379/1
REDIS_SOCKETIO_URL=redis://redis:6379/2

# S3-compatible file storage (optional — if not set, files are stored locally)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email (SMTP)
MAIL_SERVER=
MAIL_PORT=587
MAIL_LOGIN=
MAIL_PASSWORD=
MAIL_USE_TLS=1

# Frappe
FRAPPE_SITE_NAME_HEADER=$$host
SOCKETIO_PORT=9000
WEBSERVER_PORT=8000
