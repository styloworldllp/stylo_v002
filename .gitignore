# ── Site credentials & runtime data ────────────────────────────────────────
# Exclude all live site directories (contain DBs, credentials, uploads)
sites/*/
# But keep the template/shared config files
!sites/common_site_config.json
!sites/apps.txt
sites/currentsite.txt
sites/.DS_Store

# ── Node modules (rebuild per OS/arch on each machine) ─────────────────────
node_modules/
*/node_modules/
*/frontend/node_modules/
*/desk/node_modules/
# Numbered duplicates
node_modules 2/
node_modules 3/
node_modules 4/
node_modules 5/
node_modules 6/
node_modules 7/

# ── Python virtualenv & compiled files ─────────────────────────────────────
env/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# ── Logs & runtime artifacts ────────────────────────────────────────────────
logs/
*.log

# ── Archived / obsolete directories ─────────────────────────────────────────
archived/

# ── macOS clutter ────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
*.mov
*.mp4

# ── Large binaries ────────────────────────────────────────────────────────────
*.dmg
*.iso
*.img

# ── Design assets / icons (large binary files not needed in Docker build) ───
styloworld-icons 2/
stylobms-icons/
stylobms-final-icons.html
Stylo Logo/
desktop_wallpapers/
update_icon_urls.py
deploy_icons.py

# ── Duplicate directories created by macOS copy (should never exist) ────────
*\ 2/
hooks\ 2.md

# ── Build output (regenerated by bench build) ───────────────────────────────
sites/assets/
*.bundle.js
*.bundle.css

# ── Control Center runtime data ───────────────────────────────────────────────
control_center/backend/*.db
control_center/backend/.venv/
control_center/frontend/dist/

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
