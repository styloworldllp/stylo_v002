# Database
DATABASE_URL=postgresql+asyncpg://stylo:stylo@postgres:5432/stylo_control
POSTGRES_PASSWORD=change-me

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Control center admin JWT
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Email alerts
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxx
ALERT_FROM_EMAIL=alerts@styloworld.io

# Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Traefik load balancer (SSH into the Traefik host to push config)
TRAEFIK_SERVER_HOST=traefik.styloworld.io
TRAEFIK_SSH_USER=root
TRAEFIK_SSH_KEY_PATH=/root/.ssh/id_rsa
TRAEFIK_CONFIG_PATH=/etc/traefik/dynamic/sites.yml
